# 사이트 URL (Vercel 배포 시 실제 도메인으로 설정)
NEXT_PUBLIC_SITE_URL=https://example.vercel.app

# Upstash Redis (조회수 카운터 - 선택)
# https://console.upstash.com 에서 REST API 생성 후 복사
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# giscus 댓글 (선택)
# https://giscus.app 에서 설정 후 복사
NEXT_PUBLIC_GISCUS_REPO=rlaqjant/paintlater_blog
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=
